# Leave VITE_API_URL EMPTY for local-only mode (localStorage, no backend needed).
# Set it to your running backend to sync across devices, e.g. http://localhost:8787
VITE_API_URL=

# Identifies your data on the backend. Use the SAME value on every device you want synced.
VITE_USER_ID=me

# Only needed if the backend sets API_KEY (shared secret). Otherwise leave empty.
VITE_API_KEY=
