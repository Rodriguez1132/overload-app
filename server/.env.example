# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/overload
# ...or a free MongoDB Atlas cluster (paste the SRV connection string):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/overload

PORT=8787

# Optional shared secret. If set, every request must send the same value as
# VITE_API_KEY from the frontend. Leave empty for open local use.
API_KEY=
